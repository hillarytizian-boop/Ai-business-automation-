# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string-at-least-64-chars

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...your-key-here...

# ─── Admin ────────────────────────────────────────────────────────────────────
# Set a strong token used to access /admin endpoints and the admin panel
ADMIN_TOKEN=replace-with-a-strong-admin-token

# ─── Database ─────────────────────────────────────────────────────────────────
# Optional: override default DB path (default: ./data/business_assistant.db)
# DB_PATH=/data/business_assistant.db
